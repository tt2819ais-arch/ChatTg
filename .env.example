# Скопируй в .env:  cp .env.example .env
# Один ключ OpenRouter на все "мозги". Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (опционально) можно переопределить и токены ботов через окружение,
# но удобнее держать их в config.yaml. Реальные значения сюда НЕ коммить.
